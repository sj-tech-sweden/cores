# Environment Configuration for Lager Weidelbach Docker Stack
# Copy this file to .env and adjust the values for your deployment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MySQL database credentials (used by included MySQL container and both applications)
# IMPORTANT: Change these passwords in production!

DB_ROOT_PASSWORD=change_me_root_password_123
DB_NAME=RentalCore
DB_USER=rentalcore_user
DB_PASSWORD=change_me_user_password_456

# =============================================================================
# CROSS-NAVIGATION DOMAINS
# =============================================================================
# Set these to the actual DOMAINS (without protocol or port!) where your services will be accessible
# The apps will automatically use the current protocol (http/https)

# Example for server deployment with subdomains (RECOMMENDED):
# RENTALCORE_DOMAIN=rent.server-nt.de
# WAREHOUSECORE_DOMAIN=warehouse.server-nt.de
#
# With this setup:
# - No port numbers needed (handled by nginx reverse proxy)
# - Automatically uses http:// or https:// based on current page
# - Perfect for production with SSL

# For local development or port-based access, leave EMPTY:
# The apps will auto-detect and use localhost:8081 and localhost:8082

RENTALCORE_DOMAIN=
WAREHOUSECORE_DOMAIN=

# =============================================================================
# SSO COOKIE DOMAIN
# =============================================================================
# Set this to enable Single Sign-On between RentalCore and WarehouseCore
# Must start with a DOT for subdomain sharing (e.g., .server-nt.de)
# Leave EMPTY for localhost development (cookies work without domain restriction)

COOKIE_DOMAIN=

# =============================================================================
# LED MQTT CONFIGURATION (WarehouseCore)
# =============================================================================
# Self-hosted Mosquitto MQTT broker for LED warehouse bin highlighting
# Password file is automatically generated from these credentials on container startup
# To change: Edit these values and restart with `docker compose restart mosquitto`

LED_MQTT_HOST=mosquitto
LED_MQTT_PORT=1883
LED_MQTT_TLS=false
LED_MQTT_USER=leduser
LED_MQTT_PASS=ledpassword123
LED_MQTT_TOPIC_PREFIX=weidelbach
LED_WAREHOUSE_ID=WDL  # Main warehouse zone code from storage_zones table
LED_MQTT_CONNECT_RETRIES=10
LED_MQTT_CONNECT_RETRY_DELAY_MS=2000
ADMIN_NAME_MATCH=Noah Tielmann

# =============================================================================
# NEXTCLOUD FILE POOL (RentalCore)
# =============================================================================
# Optional: enable synchronization with a Nextcloud WebDAV file pool.
# Leave these empty to disable Nextcloud integration.
NEXTCLOUD_WEBDAV_URL=https://cloud.example.com/remote.php/dav/files/username
NEXTCLOUD_WEBDAV_USER=your-nextcloud-user
NEXTCLOUD_WEBDAV_PASSWORD=nextcloud-app-password
NEXTCLOUD_WEBDAV_BASE_PATH=rentalcore-filepool
# Set to false to skip automatic backfill of existing files on startup
# NEXTCLOUD_BACKFILL_ON_START=true

# For cloud MQTT broker (EMQX, HiveMQ, etc.), uncomment and configure:
# LED_MQTT_HOST=your-broker.emqxsl.com
# LED_MQTT_PORT=8883
# LED_MQTT_TLS=true
# LED_MQTT_USER=your_cloud_username
# LED_MQTT_PASS=your_cloud_password

# =============================================================================
# NOTES
# =============================================================================
# - If left empty, the applications will use auto-detection based on the current URL
# - Do NOT include the protocol (http:// or https://) - it will be added automatically
# - Do NOT include port numbers - use nginx reverse proxy for production
# - For subdomain setup: only specify the domain (e.g., "rent.server-nt.de")
# - MQTT credentials: Same credentials must be used in ESP32 secrets.h for LED control
