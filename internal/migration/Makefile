.PHONY: build test clean install run help

# Variablen
BINARY_NAME=migrate-db
BUILD_DIR=../../bin
SRC_DIR=./cmd/migrate-db
GO=go

# Farben fГјr Ausgabe
GREEN=\033[0;32m
YELLOW=\033[1;33m
NC=\033[0m # No Color

help: ## Hilfe anzeigen
	@echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
	@echo "в•‘     рҹ—„пёҸ  MySQL вҶ’ SQLite Migration Tool - Makefile            в•‘"
	@echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ"
	@echo ""
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'

build: ## Tool kompilieren
	@echo "$(GREEN)рҹ”Ё Kompiliere $(BINARY_NAME)...$(NC)"
	@mkdir -p $(BUILD_DIR)
	CGO_ENABLED=1 $(GO) build -o $(BUILD_DIR)/$(BINARY_NAME) $(SRC_DIR)
	@echo "$(GREEN)вң… Binary erstellt: $(BUILD_DIR)/$(BINARY_NAME)$(NC)"

build-local: ## Lokal kompilieren (aktuelles Verzeichnis)
	@echo "$(GREEN)рҹ”Ё Kompiliere $(BINARY_NAME) lokal...$(NC)"
	CGO_ENABLED=1 $(GO) build -o $(BINARY_NAME) $(SRC_DIR)
	@echo "$(GREEN)вң… Binary erstellt: ./$(BINARY_NAME)$(NC)"

test: ## Tests ausfГјhren
	@echo "$(GREEN)рҹ§Ә FГјhre Tests aus...$(NC)"
	$(GO) test -v ./...

test-coverage: ## Tests mit Coverage
	@echo "$(GREEN)рҹ§Ә Tests mit Coverage...$(NC)"
	$(GO) test -v -coverprofile=coverage.out ./...
	$(GO) tool cover -html=coverage.out -o coverage.html
	@echo "$(GREEN)вң… Coverage Report: coverage.html$(NC)"

clean: ## Build-Artefakte lГ¶schen
	@echo "$(YELLOW)рҹ§№ RГӨume auf...$(NC)"
	rm -f $(BINARY_NAME)
	rm -f $(BUILD_DIR)/$(BINARY_NAME)
	rm -f coverage.out coverage.html
	@echo "$(GREEN)вң… AufgerГӨumt$(NC)"

install: build ## Tool installieren (nach $GOPATH/bin)
	@echo "$(GREEN)рҹ“Ұ Installiere $(BINARY_NAME)...$(NC)"
	cp $(BUILD_DIR)/$(BINARY_NAME) $(GOPATH)/bin/
	@echo "$(GREEN)вң… Installiert nach $(GOPATH)/bin/$(BINARY_NAME)$(NC)"

run: build ## Tool mit Dry-Run starten
	@echo "$(GREEN)рҹҡҖ Starte Dry-Run...$(NC)"
	$(BUILD_DIR)/$(BINARY_NAME) --help

run-example: build ## Beispiel-Migration (Dry-Run)
	@echo "$(GREEN)рҹҡҖ Beispiel Dry-Run...$(NC)"
	@echo "$(YELLOW)вҡ пёҸ  Erfordert MYSQL_DSN Umgebungsvariable$(NC)"
	$(BUILD_DIR)/$(BINARY_NAME) --source "$${MYSQL_DSN}" --target "./test.db" --dry-run --verbose

lint: ## Code linting
	@echo "$(GREEN)рҹ”Қ Linting...$(NC)"
	golangci-lint run ./...

fmt: ## Code formatieren
	@echo "$(GREEN)рҹҺЁ Formatiere Code...$(NC)"
	$(GO) fmt ./...

deps: ## AbhГӨngigkeiten aktualisieren
	@echo "$(GREEN)рҹ“Ұ Aktualisiere AbhГӨngigkeiten...$(NC)"
	$(GO) mod tidy

# Migrations-Beispiele
migrate-dry: build ## Dry-Run Migration
	@echo "$(GREEN)рҹ”Қ Dry-Run Migration...$(NC)"
	$(BUILD_DIR)/$(BINARY_NAME) \
		--source "$${MYSQL_DSN:-root:@tcp(localhost:3306)/RentalCore}" \
		--target "./rentalcore.db" \
		--dry-run \
		--verbose

migrate-real: build ## Echte Migration (Vorsicht!)
	@echo "$(YELLOW)вҡ пёҸ  ACHTUNG: Echte Migration!$(NC)"
	@echo "$(YELLOW)   DrГјcken Sie CTRL+C innerhalb von 5 Sekunden zum Abbrechen...$(NC)"
	@sleep 5
	$(BUILD_DIR)/$(BINARY_NAME) \
		--source "$${MYSQL_DSN:-root:@tcp(localhost:3306)/RentalCore}" \
		--target "./rentalcore.db" \
		--validate

export-order: build ## Tabellen-Reihenfolge exportieren
	@echo "$(GREEN)рҹ“Ӣ Exportiere Tabellen-Reihenfolge...$(NC)"
	$(BUILD_DIR)/$(BINARY_NAME) \
		--source "$${MYSQL_DSN:-root:@tcp(localhost:3306)/RentalCore}" \
		--export-order "./table_order_live.json" \
		--dry-run
