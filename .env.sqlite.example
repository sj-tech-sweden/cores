# =============================================================================
# SQLite Docker Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed
# For SQLite, most MySQL-related variables are no longer needed!
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration (for cross-navigation and SSO)
# -----------------------------------------------------------------------------
# Leave empty for auto-detection based on current hostname
RENTALCORE_DOMAIN=
WAREHOUSECORE_DOMAIN=

# Cookie domain for SSO (e.g., .example.com for subdomains)
# Leave empty for localhost development
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# SQLite Database Configuration (NEW!)
# -----------------------------------------------------------------------------
# Database files are stored in a shared volume at /data/
# These settings are automatically applied via docker-compose.yml

# SQLite Pragmas (optional, sensible defaults are used)
# DB_JOURNAL_MODE=WAL          # WAL, DELETE, TRUNCATE, PERSIST, MEMORY, OFF
# DB_SYNCHRONOUS=NORMAL        # OFF, NORMAL, FULL, EXTRA  
# DB_CACHE_SIZE=-64000         # Negative = KB, Positive = Pages (64MB default)
# DB_BUSY_TIMEOUT=5000         # Milliseconds to wait when locked (5s default)

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7        # Days to keep backups
BACKUP_INTERVAL_HOURS=24       # Hours between automatic backups

# -----------------------------------------------------------------------------
# Nextcloud File Pool (WebDAV) - Optional
# -----------------------------------------------------------------------------
NEXTCLOUD_WEBDAV_URL=
NEXTCLOUD_WEBDAV_USER=
NEXTCLOUD_WEBDAV_PASSWORD=
NEXTCLOUD_WEBDAV_BASE_PATH=rentalcore-filepool
NEXTCLOUD_BACKFILL_ON_START=true

# -----------------------------------------------------------------------------
# MQTT Configuration (for LED system)
# -----------------------------------------------------------------------------
LED_MQTT_HOST=mosquitto
LED_MQTT_PORT=1883
LED_MQTT_TLS=false
LED_MQTT_USER=leduser
LED_MQTT_PASS=ledpassword123
LED_MQTT_TOPIC_PREFIX=weidelbach
LED_WAREHOUSE_ID=weidelbach
LED_MQTT_CONNECT_RETRIES=10
LED_MQTT_CONNECT_RETRY_DELAY_MS=2000

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ADMIN_NAME_MATCH=Noah Tielmann
OCR_USE_PYTHON=true
